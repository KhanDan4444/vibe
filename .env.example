# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (local dev)
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=gym_saas
DB_PASSWORD=
DB_PORT=5432

# Cloud (Neon + Railway): use DATABASE_URL instead of the vars above
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# DB_SSL=1   — required when using DB_HOST/DB_* against Neon (not needed with DATABASE_URL)

# Auth — required; server refuses to start without JWT_SECRET
JWT_SECRET=change-me-to-a-long-random-string

# Dev-only: secret for POST /api/auth/register-admin (disabled in production)
# Send as header: X-Admin-Setup-Secret: <value>
ADMIN_SETUP_SECRET=dev-only-change-me

# CORS allowlist (comma-separated frontend origins)
# Dev: optional — defaults to http://localhost:5173 and other local Vite ports
# Production: required — server exits on startup if unset
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.example.com

# Set to 1 when behind a reverse proxy (needed for accurate rate-limit IP)
# TRUST_PROXY=1

# Frontend URL (password reset links)
FRONTEND_URL=http://localhost:5173

# Email (optional — without SMTP, emails are logged to the server console)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=your-user
# SMTP_PASS=your-password
# SMTP_FROM=VibeSaaS <noreply@example.com>

# Afro Message SMS (https://www.afromessage.com/developers)
# Without AFRO_MESSAGE_TOKEN, OTP codes and SMS are logged to the server console (dev only).
# AFRO_MESSAGE_TOKEN=your-api-token
# Beta: do not set SENDER or FROM — Afro applies the default sender (AfroMessage) automatically.
# After your custom sender is approved: AFRO_MESSAGE_SENDER=YourVerifiedName
# Optional identifier (Identifiers page): AFRO_MESSAGE_FROM=your-identifier-id
# AFRO_MESSAGE_OTP_TTL=600
# AFRO_MESSAGE_OTP_LENGTH=6

# Public gym self-registration (set to 0 to disable)
PUBLIC_GYM_SIGNUP_ENABLED=1

# PostgreSQL connection pool (optional tuning)
# DB_POOL_MAX=20
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=5000
